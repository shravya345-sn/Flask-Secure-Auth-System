# Python bytecode (compiled files that clutter the repo)
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (large folders that shouldn't be uploaded)
venv/
.venv/
env/
bin/
lib/

# Databases and Secrets
# Ignore the old SQLite database and any environment secret files
instance/
*.db
.env

# Unit test / coverage reports
.pytest_cache/
.coverage
htmlcov/

# Operating System files
.DS_Store
Thumbs.db